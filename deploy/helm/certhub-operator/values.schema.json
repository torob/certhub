{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "replicaCount",
    "image",
    "clusterScoped",
    "watchNamespaces",
    "rbac",
    "serviceAccount",
    "certhub",
    "metrics",
    "networkPolicy"
  ],
  "properties": {
    "global": {
      "type": "object"
    },
    "nameOverride": {
      "$ref": "#/definitions/optionalDnsLabel"
    },
    "fullnameOverride": {
      "type": "string",
      "maxLength": 63,
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$|^$"
    },
    "replicaCount": {
      "type": "integer",
      "const": 1
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "tag",
        "digest",
        "pullPolicy"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "maxLength": 128,
          "pattern": "^$|^[A-Za-z0-9_][A-Za-z0-9_.-]{0,127}$"
        },
        "digest": {
          "type": "string",
          "pattern": "^$|^sha256:[a-f0-9]{64}$"
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        }
      },
      "not": {
        "allOf": [
          {
            "properties": {
              "tag": {
                "minLength": 1
              }
            }
          },
          {
            "properties": {
              "digest": {
                "minLength": 1
              }
            }
          }
        ]
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "$ref": "#/definitions/dnsSubdomain"
          }
        }
      }
    },
    "clusterScoped": {
      "type": "boolean"
    },
    "watchNamespaces": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/dnsLabel"
      }
    },
    "rbac": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "create"
      ],
      "properties": {
        "create": {
          "type": "boolean"
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "create",
        "name",
        "annotations"
      ],
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "$ref": "#/definitions/optionalDnsSubdomain"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        }
      }
    },
    "certhub": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "tokenSecretName",
        "tokenSecretKey",
        "resyncInterval",
        "reconcileBackoff",
        "httpTimeout",
        "httpRetryMaxAttempts",
        "httpRetryInitialBackoff",
        "httpRetryMaxBackoff"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://\\S+$"
        },
        "tokenSecretName": {
          "$ref": "#/definitions/dnsSubdomain"
        },
        "tokenSecretKey": {
          "type": "string",
          "minLength": 1,
          "maxLength": 253,
          "pattern": "^[-._a-zA-Z0-9]+$"
        },
        "resyncInterval": {
          "$ref": "#/definitions/duration"
        },
        "reconcileBackoff": {
          "$ref": "#/definitions/duration"
        },
        "httpTimeout": {
          "$ref": "#/definitions/duration"
        },
        "httpRetryMaxAttempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "httpRetryInitialBackoff": {
          "$ref": "#/definitions/duration"
        },
        "httpRetryMaxBackoff": {
          "$ref": "#/definitions/duration"
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service",
        "serviceMonitor"
      ],
      "properties": {
        "service": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "port",
            "annotations",
            "labels"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "annotations": {
              "$ref": "#/definitions/stringMap"
            },
            "labels": {
              "$ref": "#/definitions/stringMap"
            }
          }
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "additionalLabels",
            "interval",
            "scrapeTimeout"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "additionalLabels": {
              "$ref": "#/definitions/stringMap"
            },
            "interval": {
              "$ref": "#/definitions/duration"
            },
            "scrapeTimeout": {
              "$ref": "#/definitions/duration"
            }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "provider",
        "kubernetes",
        "cilium"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "provider": {
          "type": "string",
          "enum": [
            "kubernetes",
            "cilium"
          ]
        },
        "kubernetes": {
          "$ref": "#/definitions/networkPolicyRules"
        },
        "cilium": {
          "$ref": "#/definitions/networkPolicyRules"
        }
      }
    },
    "resources": {
      "type": "object"
    },
    "podAnnotations": {
      "$ref": "#/definitions/stringMap"
    },
    "podLabels": {
      "$ref": "#/definitions/stringMap"
    },
    "priorityClassName": {
      "type": "string"
    },
    "nodeSelector": {
      "type": "object"
    },
    "tolerations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object"
    },
    "topologySpreadConstraints": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 10
    },
    "probes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "liveness",
        "readiness"
      ],
      "properties": {
        "liveness": {
          "$ref": "#/definitions/probe"
        },
        "readiness": {
          "$ref": "#/definitions/probe"
        }
      }
    },
    "podSecurityContext": {
      "type": "object"
    },
    "securityContext": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "clusterScoped": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "watchNamespaces": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "metrics": {
            "properties": {
              "serviceMonitor": {
                "properties": {
                  "enabled": {
                    "const": true
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "metrics": {
            "properties": {
              "service": {
                "properties": {
                  "enabled": {
                    "const": true
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "networkPolicy": {
            "required": [
              "enabled",
              "provider"
            ],
            "properties": {
              "enabled": {
                "const": true
              },
              "provider": {
                "const": "kubernetes"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "networkPolicy": {
            "properties": {
              "kubernetes": {
                "$ref": "#/definitions/configuredNetworkPolicyRules"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "networkPolicy": {
            "required": [
              "enabled",
              "provider"
            ],
            "properties": {
              "enabled": {
                "const": true
              },
              "provider": {
                "const": "cilium"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "networkPolicy": {
            "properties": {
              "cilium": {
                "$ref": "#/definitions/configuredNetworkPolicyRules"
              }
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "dnsLabel": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "optionalDnsLabel": {
      "type": "string",
      "maxLength": 63,
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$|^$"
    },
    "dnsSubdomain": {
      "type": "string",
      "minLength": 1,
      "maxLength": 253,
      "pattern": "^[a-z0-9](?:[-a-z0-9.]*[a-z0-9])?$"
    },
    "optionalDnsSubdomain": {
      "type": "string",
      "maxLength": 253,
      "pattern": "^[a-z0-9](?:[-a-z0-9.]*[a-z0-9])?$|^$"
    },
    "duration": {
      "type": "string",
      "pattern": "^(?:[0-9]+(?:\\.[0-9]+)?(?:ns|us|µs|ms|s|m|h))+$"
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "networkPolicyRules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ingress": {
          "$ref": "#/definitions/nullableRuleList"
        },
        "egress": {
          "$ref": "#/definitions/nullableRuleList"
        }
      }
    },
    "configuredNetworkPolicyRules": {
      "allOf": [
        {
          "$ref": "#/definitions/networkPolicyRules"
        },
        {
          "anyOf": [
            {
              "required": [
                "ingress"
              ],
              "properties": {
                "ingress": {
                  "type": "array"
                }
              }
            },
            {
              "required": [
                "egress"
              ],
              "properties": {
                "egress": {
                  "type": "array"
                }
              }
            }
          ]
        }
      ]
    },
    "nullableRuleList": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object"
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "initialDelaySeconds",
        "periodSeconds",
        "timeoutSeconds",
        "failureThreshold"
      ],
      "properties": {
        "initialDelaySeconds": {
          "type": "integer",
          "minimum": 0
        },
        "periodSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "failureThreshold": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
